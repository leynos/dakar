{
  "adapters": {
    "codex-low": {
      "label": "Codex CLI, low reasoning",
      "command": [
        "codex",
        "exec",
        "--skip-git-repo-check",
        "--sandbox",
        "workspace-write",
        "--cd",
        "{workspace}",
        "-c",
        "model_reasoning_effort=\"low\"",
        "-"
      ],
      "stdin": "{prompt}",
      "flags": {
        "model": [
          "--model"
        ]
      }
    },
    "codex-medium": {
      "label": "Codex CLI, medium reasoning",
      "command": [
        "codex",
        "exec",
        "--skip-git-repo-check",
        "--sandbox",
        "workspace-write",
        "--cd",
        "{workspace}",
        "-c",
        "model_reasoning_effort=\"medium\"",
        "-"
      ],
      "stdin": "{prompt}",
      "flags": {
        "model": [
          "--model"
        ]
      }
    },
    "codex-high": {
      "label": "Codex CLI, high reasoning",
      "command": [
        "codex",
        "exec",
        "--skip-git-repo-check",
        "--sandbox",
        "workspace-write",
        "--cd",
        "{workspace}",
        "-c",
        "model_reasoning_effort=\"high\"",
        "-"
      ],
      "stdin": "{prompt}",
      "flags": {
        "model": [
          "--model"
        ]
      }
    },
    "pi-luna-flex": {
      "label": "pi coding agent, Luna, Flex processing, low reasoning",
      "command": [
        "pi",
        "-p",
        "--no-session",
        "--provider",
        "openai-flex",
        "--model",
        "gpt-5.6-luna",
        "--thinking",
        "low"
      ],
      "stdin": "{prompt}"
    },
    "pi-luna-flex-medium": {
      "label": "pi coding agent, Luna, Flex processing, medium reasoning",
      "command": [
        "pi",
        "-p",
        "--no-session",
        "--provider",
        "openai-flex",
        "--model",
        "gpt-5.6-luna",
        "--thinking",
        "medium"
      ],
      "stdin": "{prompt}"
    },
    "pi-terra-flex": {
      "label": "pi coding agent, Terra, Flex processing, medium reasoning",
      "command": [
        "pi",
        "-p",
        "--no-session",
        "--provider",
        "openai-flex",
        "--model",
        "gpt-5.6-terra",
        "--thinking",
        "medium"
      ],
      "stdin": "{prompt}"
    }
  }
}
